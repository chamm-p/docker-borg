# === Central Server ===
CENTRAL_URL=http://central:8080
REGISTRATION_TOKEN=change-me-to-a-secure-token
SECRET_KEY=change-me-random-secret

# === Agent ===
AGENT_NAME=my-host
BORG_REPO=/backups
BORG_PASSPHRASE=change-me-secure-passphrase
DOCKER_HOST_DIR=/home/user/docker
POLL_INTERVAL=30

# === Backup Target (examples) ===
# Local:    /backups
# SFTP:     ssh://user@backup-server/path/to/repo
# Mounted:  /mnt/webdav/borg-repo
