# Agent name (shown in central Web UI)
DBORG_AGENT_NAME=my-host

# Central server URL
DBORG_CENTRAL_URL=http://central-ip:8080

# Registration token (must match central)
DBORG_REGISTRATION_TOKEN=change-me

# Docker directory on the HOST (mounted read-only into agent)
DOCKER_HOST_DIR=/home/user/docker

# Borg repo + passphrase are managed via Central Web UI.
# Only set these for standalone use without central:
# DBORG_BORG_REPO=/backups
# DBORG_BORG_PASSPHRASE=change-me
