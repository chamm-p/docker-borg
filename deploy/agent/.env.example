# Agent — Konfiguration. Nach deploy/agent/ kopieren als ".env"
# und ausfüllen:   cp .env.example .env
# .env ist gitignored und wird NICHT eingecheckt.

# Zeitzone
TZ=Europe/Zurich

# Eindeutiger Name dieses Agents (taucht so in der UI auf), z.B. vzulu2
DBORG_AGENT_NAME=

# URL des Central — IP/Host + Host-Port (Default 8089, siehe Central-.env)
DBORG_CENTRAL_URL=http://CENTRAL-IP:8089

# Pre-shared Token — MUSS identisch zum Central sein.
DBORG_REGISTRATION_TOKEN=

# Host-Pfad, unter dem deine Compose-Projekte liegen (z.B. /sync/Docker oder
# /home/user/docker). Wird read-only in den Agent gemountet; der Agent leitet
# daraus die Backup-Pfade ab.
DBORG_HOST_BASE_DIR=/home/user/docker
