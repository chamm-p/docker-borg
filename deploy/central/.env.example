# Central / Backend — Konfiguration. Nach deploy/central/ kopieren als ".env"
# und ausfüllen:   cp .env.example .env
# .env ist gitignored und wird NICHT eingecheckt.

# Zeitzone
TZ=Europe/Zurich

# Host-Port der Web-UI (8080 war belegt → 8089). Dieser Port muss in der
# DBORG_CENTRAL_URL der Agents stehen.
DBORG_CENTRAL_PORT=8089

# Pre-shared Token, mit dem sich Agents registrieren. MUSS bei allen Agents
# identisch sein. Erzeugen:  openssl rand -hex 24
DBORG_REGISTRATION_TOKEN=

# Login-Passwort für die Web-UI (frei wählbar).
DBORG_ADMIN_PASSWORD=

# Session-/Krypto-Secret der App. Erzeugen:  openssl rand -hex 24
DBORG_SECRET_KEY=

# Log-Level: INFO oder DEBUG
DBORG_LOG_LEVEL=INFO

# ── E-Mail-Benachrichtigung (optional) ──────────────────────────────
# Leer lassen = deaktiviert. Beispiel für STARTTLS (Port 587):
#   DBORG_SMTP_HOST=smtp.example.org
#   DBORG_SMTP_USER=backup@example.org
#   DBORG_SMTP_PASSWORD=geheim
#   DBORG_SMTP_TO=admin@example.org
DBORG_SMTP_HOST=
DBORG_SMTP_PORT=587
DBORG_SMTP_USER=
DBORG_SMTP_PASSWORD=
# Absender (leer = SMTP_USER)
DBORG_SMTP_FROM=
# Empfänger, mehrere kommagetrennt
DBORG_SMTP_TO=
# STARTTLS (Port 587). Für implizites TLS (Port 465): TLS=false, SSL=true
DBORG_SMTP_TLS=true
DBORG_SMTP_SSL=false
# Wann benachrichtigen: failure (nur Fehler, Default) | always | off
DBORG_NOTIFY=failure
