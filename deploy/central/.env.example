# Central / Backend — Konfiguration. Nach deploy/central/ kopieren als ".env"
# und ausfüllen:   cp .env.example .env
# .env ist gitignored und wird NICHT eingecheckt.

# Zeitzone
TZ=Europe/Zurich

# Host-Port der Web-UI (8080 war belegt → 8089). Dieser Port muss in der
# DBORG_CENTRAL_URL der Agents stehen.
DBORG_CENTRAL_PORT=8089

# Pre-shared Token, mit dem sich Agents registrieren. MUSS bei allen Agents
# identisch sein. Erzeugen:  openssl rand -hex 24
DBORG_REGISTRATION_TOKEN=

# Login-Passwort für die Web-UI (frei wählbar).
DBORG_ADMIN_PASSWORD=

# Session-/Krypto-Secret der App. Erzeugen:  openssl rand -hex 24
DBORG_SECRET_KEY=

# Log-Level: INFO oder DEBUG
DBORG_LOG_LEVEL=INFO
